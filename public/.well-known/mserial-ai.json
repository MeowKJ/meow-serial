    "primer_url": "/ai/custom-parser-primer.json",
    "schema_url": "/ai/protocol-profile.schema.json",
    "playbook_url": "/ai/agent-playbook.json",
    "supported_kinds": ["line-values", "json-lines", "tlv"],
